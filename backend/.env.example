# Boiler Dosing Controller - Backend Configuration
# Copy this file to .env and customize values

# Database credentials
DB_PASSWORD=your_secure_database_password_here

# API authentication key (set same value in ESP32 firmware)
API_KEY=your_secure_api_key_here

# Grafana admin password
GRAFANA_PASSWORD=your_grafana_admin_password

# Optional: Change ports if needed (defaults shown)
# API_PORT=3000
# GRAFANA_PORT=3001
# DB_PORT=5432

# MQTT gateway (Phase E) - when ESP32 uses MQTT telemetry
# Broker URL; set to enable subscribing to device/+/metrics, alarm, health
# MQTT_URL=mqtt://localhost:1883
# MQTT_ENABLED=true
